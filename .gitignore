# ~/founderos/.gitignore

# ============================================
# Environment & Secrets
# ============================================
.env
.env.local
.env.production
.env.*.local
*.env
!.env.example
!.env.template

# Secrets and certificates
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
ssl/
certificates/
secrets/

# ============================================
# Docker & Container Data
# ============================================
# Data volumes (contains your actual database!)
data/
docker-data/
volumes/

# Docker files we don't want to commit
docker-compose.override.yml
.dockerignore.local

# ============================================
# Database
# ============================================
*.sql
!database/init.sql
!database/migrations/*.sql
*.dump
*.backup
*.bak
backups/
postgres-data/
mysql-data/

# ============================================
# Email Server Data
# ============================================
email/data/
email/state/
email/logs/
email/config/*
!email/config/.gitkeep
mail-data/
mail-state/

# ============================================
# Node.js & JavaScript
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn
package-lock.json
yarn.lock
!backend/package-lock.json
!frontend/package-lock.json

# Build outputs
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/
*.local

# TypeScript
*.tsbuildinfo
.tsc-cache/

# Testing
coverage/
.nyc_output/
test-results/
*.lcov
.coverage

# ============================================
# Redis
# ============================================
redis-data/
dump.rdb
appendonly.aof

# ============================================
# Elasticsearch
# ============================================
elasticsearch-data/
elastic-data/

# ============================================
# Logs & Temporary Files
# ============================================
logs/
*.log
*.log.*
log/
tmp/
temp/
.tmp/

# PM2
.pm2/
pm2.log

# ============================================
# IDE & Editors
# ============================================
# VSCode
.vscode/
!.vscode/settings.json.example
!.vscode/tasks.json.example
!.vscode/launch.json.example
!.vscode/extensions.json.example
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn
*.vim
.vim/
*~

# Emacs
*~
\#*\#
.\#*
.emacs.desktop
.emacs.desktop.lock

# TextMate
*.tmproj
*.tmproject

# ============================================
# Operating System Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.DocumentRevisions-V100
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================
# Application Specific
# ============================================
# Uploaded files (keep structure, not content)
uploads/*
!uploads/.gitkeep
public/uploads/*
!public/uploads/.gitkeep

# User generated content
user-content/
user-data/
attachments/

# Sessions
sessions/
.sessions/

# Cache
cache/
.cache/
*.cache

# Static files (if generated)
public/static/
static/css/
static/js/
!static/css/.gitkeep
!static/js/.gitkeep

# ============================================
# Security & Monitoring
# ============================================
# Audit logs with sensitive data
audit-logs/
security-logs/

# Monitoring
grafana-data/
prometheus-data/
metrics/

# ============================================
# Backups
# ============================================
*.backup
*.bak
*.old
backup/
backups/
db-backups/

# ============================================
# Development & Debug
# ============================================
.env.development.local
.env.test.local
debug/
.debug/
*.heapsnapshot
*.cpuprofile
*.trace

# Hot reload
.hot/
hot/

# ============================================
# Dependencies & Package Managers
# ============================================
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Ruby
*.gem
*.rbc
.bundle/
vendor/bundle

# PHP
vendor/
composer.phar

# ============================================
# Documentation (if generated)
# ============================================
docs/_build/
docs/.vuepress/dist/
site/

# API documentation
api-docs/
swagger-ui/

# ============================================
# Miscellaneous
# ============================================
# Terraform
*.tfstate
*.tfstate.*
.terraform/

# Ansible
*.retry

# Kubernetes
kubeconfig
*.kubeconfig

# Ignore everything in scripts except examples and utilities
scripts/*
!scripts/*.example
!scripts/*.template
!scripts/start.sh
!scripts/stop.sh
!scripts/logs.sh

# Keep important files
!.gitignore
!.dockerignore
!README.md
!LICENSE
!docker-compose.yml
!docker-compose.example.yml
!Dockerfile
# ~/founderos/.env.example

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Domain & URLs
DOMAIN=founderos.local
APP_URL=http://localhost
API_URL=http://localhost:3000

# Database (PostgreSQL)
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
DB_HOST=postgres
DB_PORT=5432
DB_NAME=founderos
DB_USER=founderos

# Security (Generate random strings!)
JWT_SECRET=CHANGE_THIS_MINIMUM_32_CHARACTERS_RANDOM_STRING
ENCRYPTION_KEY=CHANGE_THIS_MINIMUM_32_CHARACTERS_RANDOM_STRING

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration
MAIL_FROM_ADDRESS=noreply@founderos.local
MAIL_FROM_NAME=FounderOS
SMTP_HOST=mailserver
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Environment
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# AWS (for S3, SES, etc)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Sentry (Error Tracking)
SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_SIGNUPS=true
ENABLE_OAUTH=false
ENABLE_2FA=false
ENABLE_API_RATE_LIMIT=true
ENABLE_WEBSOCKETS=true

# ============================================
# LIMITS & QUOTAS
# ============================================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
MAX_USERS_PER_ORG=50
MAX_PROJECTS_PER_ORG=100
API_RATE_LIMIT=100  # requests per minute

# ============================================
# DEVELOPMENT
# ============================================
DEBUG=false
FORCE_SSL=false
TRUST_PROXY=true